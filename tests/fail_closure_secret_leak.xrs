// R3 (secret-containment) holds *through* a closure body (spec 19): a `ui` fn
// can't read a secret field inside a `map` either — the tier rules propagate into
// the closure for free, so no new rule is needed. This must be rejected.
model User {
  id: String
  secret password: String
}

ui fn leak(users: List<User>) -> List<String> {
  return users.map(u -> u.password)
}
