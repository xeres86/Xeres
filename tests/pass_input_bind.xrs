// EXPECT: PASS — an input is two-way bound to a String state cell; the add
// handler reads it, appends a task, and clears the field.
model Task {
  id: String
  title: String
  done: Bool
}

synced state tasks: Collection<Task>

ui screen Todo {
  state draft: String = ""

  view {
    column {
      heading "Xeres Todo"
      row {
        input "What needs doing?" bind draft
        button "add" -> { tasks.add(Task { id: uid(), title: draft, done: false }) draft = "" }
      }
      for task in tasks {
        row {
          text task.title
        }
      }
    }
  }
}
