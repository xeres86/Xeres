// A server fn returning a bare scalar built from a secret field is fine once
// wrapped in declassify(...) — the deliberate-release escape hatch (R5/R6).
model User {
  id: String
  secret password_hash: String
}

server fn get_hash(user: User) -> String {
  return declassify(user.password_hash)
}

ui screen Home {
  view {
    heading "hi"
  }
}
