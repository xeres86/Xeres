// EXPECT: FAIL [R5 secret-leak-via-return] — a `server fn` returning a bare
// scalar built from a secret field has no wire protection (only a Model
// return gets its `secret` fields stripped automatically); this compiled
// clean before the spec-29 sweep and the raw value crossed the wire on
// `/__xeres/get_hash` — confirmed live, not theoretical.
model User {
  id: String
  secret password_hash: String
}

server fn get_hash(user: User) -> String {
  return user.password_hash
}

ui screen Home {
  view {
    heading "hi"
  }
}
