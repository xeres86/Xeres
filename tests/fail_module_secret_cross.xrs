// fail_module_secret_cross.xrs — a `secret` cannot be leaked across the module
// boundary: the tier/secret rules (R3 secret-containment / R5 secret-via-return)
// run on the MERGED program, so reading another module's secret field in a
// non-server function is rejected. Modules can't widen the boundary (spec 20).
import "accounts.xrs"

fn reveal(a: Account) -> String {
    return a.pin
}
