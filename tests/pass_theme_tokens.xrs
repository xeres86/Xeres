// a `theme`, a named `style`, `token(...)` usage, and a `theme dark` set (spec 26)
theme {
  color primary "#2563eb"
  space lg "24px"
}

theme dark {
  color primary "#7c3aed"
}

style Card {
  "padding:24px; border-radius:12px; background:token(primary); gap:token(lg)"
}

ui screen Home {
  view {
    column style Card {
      heading "Dashboard"
      row style "color:token(primary)" { text "themed text" }
      button "Toggle theme" -> { toggle_theme() }
    }
  }
}
