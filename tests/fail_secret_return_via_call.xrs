// EXPECT: FAIL [R5 secret-leak-via-return] — a non-server fn's return value is
// tainted by CALLING a server fn that returns secret-derived data (the
// composition/propagation path through `returns_secret`, not a direct field
// read — that's R3's job, exercised by fail_secret_return.xrs). `get_hash`
// itself is fine (Model return, wire-projection strips the `secret` field
// automatically); `leak` re-exposing it outside `server` isn't.
model User {
  id: String
  secret password_hash: String
}

server fn get_hash(user: User) -> User {
  return User { id: user.id, password_hash: user.password_hash }
}

fn leak(user: User) -> User {
  return get_hash(user)
}
